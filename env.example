# Скопируйте в .env.local в корне `tp/`, подставьте значения, перезапустите `npm run dev`.
# Секреты в репозиторий не коммитятся (.gitignore: .env*).

# https://api.deepseek.com — DeepSeek
DEEPSEEK_API_KEY=

# Google Cloud: Custom Search API + Programmable Search Engine (cx)
# + Places API (Text Search, Details, Photo) для фото мест как в Google Maps
# https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
# Только Places (если отдельный ключ; иначе = GOOGLE_API_KEY)
# GOOGLE_PLACES_API_KEY=

# Кабинет разработчика Яндекс.Карт (JavaScript API) — нужен, если карта через Яндекс
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# Google Maps JavaScript API + Directions. Если задан — по умолчанию карта маршрута через Google (лучше для пеших маршрутов за пределами РФ).
# Чтобы оставить подложку Яндекс при наличии обоих ключей и строить линию через Google Directions при отказе Яндекс-маршрутизации — установите:
# NEXT_PUBLIC_USE_YANDEX_MAP=1
NEXT_PUBLIC_USE_YANDEX_MAP=

# https://developers.google.com/maps/documentation/javascript/get-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
